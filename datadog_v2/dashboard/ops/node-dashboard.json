{
  "title": "Redis Enterprise - Node Dashboard",
  "description": "Import-safe Datadog version of Node Dashboard.",
  "widgets": [
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "Overview",
        "widgets": [
          {
            "definition": {
              "type": "query_value",
              "title": "Status",
              "requests": [
                {
                  "q": "avg:rdse2.node_metrics_up{$cluster}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "Enterprise Version ",
              "requests": [
                {
                  "q": "avg:rdse2.node_config{$cluster}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "Role",
              "requests": [
                {
                  "q": "max:rdse2.is_primary{$cluster,$node}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "# Shards",
              "requests": [
                {
                  "q": "count_nonzero(avg:rdse2.redis_server_up{$cluster,$node} by {redis})",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "CPU Utilization",
              "requests": [
                {
                  "q": "(sum:rdse2.node_cpu_seconds_total.count{$cluster,$node,!mode:idle}.as_rate() / count:rdse2.node_cpu_seconds_total.count{$cluster,$node,mode:idle}) * 100",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2,
              "custom_unit": "%"
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "Free RAM",
              "requests": [
                {
                  "q": "avg:rdse2.node_available_memory_bytes{$cluster}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          }
        ]
      }
    },
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "CPU",
        "widgets": [
          {
            "definition": {
              "type": "query_value",
              "title": "Node IN Quorum?",
              "requests": [
                {
                  "q": "avg:rdse2.has_quorum{$cluster,$node}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "OS version",
              "requests": [
                {
                  "q": "avg:rdse2.node_os_info{$cluster}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "Instance",
              "requests": [
                {
                  "q": "avg:rdse2.node_dmi_info{$cluster}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "# Databases",
              "requests": [
                {
                  "q": "count_nonzero(avg:rdse2.endpoint_client_connections{$cluster} by {db})",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "CPU Usage on node (100% = 1 core)",
              "requests": [
                {
                  "q": "avg:rdse2.namedprocess_namegroup_cpu_seconds.count{$cluster,$node}.as_rate()",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                }
              ],
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value"
              ],
              "yaxis": {
                "include_zero": true
              }
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "DMC Proxy CPU Usage on node",
              "requests": [
                {
                  "q": "avg:rdse2.namedprocess_namegroup_cpu_seconds.count{$cluster,$node}.as_rate()",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                }
              ],
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value"
              ],
              "yaxis": {
                "include_zero": true
              }
            }
          }
        ]
      }
    },
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "Traffic",
