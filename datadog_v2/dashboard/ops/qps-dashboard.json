{
  "title": "Redis Enterprise - RediSearch QPS dashboard",
  "description": "RediSearch QPS dashboard migrated from Grafana v2 ops analysis. Queries prefer panel intent over exact PromQL parity and include known Datadog semantic notes in validation reports.",
  "widgets": [
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "General",
        "widgets": [
          {
            "definition": {
              "type": "query_value",
              "title": "Number of indexes",
              "requests": [
                {
                  "q": "avg:rdse2.redis_server_search_number_of_indexes{$cluster, $db}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Fields count",
              "requests": [
                {
                  "q": "avg:rdse2.redis_server_search_fields_text_Text{$cluster, $db}",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                },
                {
                  "q": "avg:rdse2.redis_server_search_fields_tag_Tag{$cluster, $db}",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                },
                {
                  "q": "avg:rdse2.redis_server_search_fields_numeric_Numeric{$cluster, $db}",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                },
                {
                  "q": "avg:rdse2.redis_server_search_fields_geo_Geo{$cluster, $db}",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                },
                {
                  "q": "avg:rdse2.redis_server_search_fields_geoshape_Geoshape{$cluster, $db}",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                },
                {
                  "q": "avg:rdse2.redis_server_search_fields_vector_Vector{$cluster, $db}",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  }
                }
              ],
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value"
              ],
              "yaxis": {
                "include_zero": true
              }
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Active indexes",
