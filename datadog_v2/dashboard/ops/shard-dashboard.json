{
  "title": "Redis Enterprise - Shard dashboard",
  "description": "Shard dashboard migrated from Grafana v2 ops analysis. Queries prefer panel intent over exact PromQL parity and include known Datadog semantic notes in validation reports.",
  "widgets": [
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "Overview",
        "widgets": [
          {
            "definition": {
              "type": "query_value",
              "title": "Used Memory",
              "requests": [
                {
                  "q": "avg:rdse2.redis_server_used_memory{$db, $redis, $cluster}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "#Keys",
              "requests": [
                {
                  "q": "sum:rdse2.redis_server_db_keys{$cluster, $db, $redis}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "query_value",
              "title": "#Connections",
              "requests": [
                {
                  "q": "avg:rdse2.redis_server_connected_clients{$db, $redis, $cluster}",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          },
          {
            "definition": {
              "type": "toplist",
              "title": "Node #",
              "requests": [
                {
                  "q": "top(avg:rdse2.redis_server_up{$cluster,$db,$redis} by {node}, 1, 'last', 'desc')"
                }
              ]
            }
          },
          {
            "definition": {
              "type": "toplist",
              "title": "Role",
              "requests": [
                {
                  "q": "top(avg:rdse2.redis_server_up{$cluster,$db,$redis} by {role}, 1, 'last', 'desc')"
                }
              ]
            }
          }
        ]
      }
    },
    {
