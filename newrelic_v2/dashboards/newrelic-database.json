                "warningViolations": false
              }
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  6704154
                ],
                "query": "SELECT sum(redis_server_used_memory) \n  FROM Metric\n  FACET cluster, db\n  WHERE cluster IN ({{cluster}}) AND db IN ({{db}})\n  TIMESERIES 30 seconds"
