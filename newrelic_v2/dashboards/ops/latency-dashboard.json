{
  "name": "Redis Enterprise - Latency Dashboard",
  "description": "New Relic implementation of the validated Redis Enterprise latency operations dashboard.",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Latency Dashboard",
      "description": null,
      "widgets": [
        {
          "title": "",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 12,
            "height": 1
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "# Redis Enterprise Latency Dashboard\n\nNew Relic implementation of the validated Redis Enterprise latency operations dashboard. Filter by `cluster` and `db`."
          }
        },
        {
          "title": "Avg Latency",
          "layout": {
            "column": 1,
            "row": 2,
            "width": 6,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.line"
          },
          "rawConfiguration": {
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "chartStyles": {
              "lineInterpolation": "linear"
            },
            "facet": {
              "showOtherSeries": false
            },
            "legend": {
              "enabled": true
            },
            "markers": {
              "displayedTypes": {
                "annotations": true,
                "criticalViolations": false,
                "deployments": true,
                "relatedDeployments": true,
                "warningViolations": false
              }
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM Metric SELECT (average(endpoint_read_requests_latency_histogram_sum) / average(endpoint_read_requests_latency_histogram_count)) / 1000 AS 'read ms' WHERE cluster IN ({{cluster}}) AND db IN ({{db}}) TIMESERIES 1 minute"
              },
              {
                "accountIds": [
                  0
                ],
                "query": "FROM Metric SELECT (average(endpoint_write_requests_latency_histogram_sum) / average(endpoint_write_requests_latency_histogram_count)) / 1000 AS 'write ms' WHERE cluster IN ({{cluster}}) AND db IN ({{db}}) TIMESERIES 1 minute"
              },
              {
                "accountIds": [
                  0
                ],
                "query": "FROM Metric SELECT (average(endpoint_other_requests_latency_histogram_sum) / average(endpoint_other_requests_latency_histogram_count)) / 1000 AS 'other ms' WHERE cluster IN ({{cluster}}) AND db IN ({{db}}) TIMESERIES 1 minute"
              }
            ],
            "thresholds": {
              "isLabelVisible": true
            },
            "yAxisLeft": {
              "zero": true
            },
            "yAxisRight": {
              "zero": true
            },
            "units": {
              "unit": "MS"
            }
          }
        },
        {
          "title": "#Connections",
          "layout": {
            "column": 7,
            "row": 2,
            "width": 3,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM (FROM Metric SELECT latest(endpoint_client_connections) AS connections, latest(endpoint_client_disconnections) AS client_disconnections, latest(endpoint_proxy_disconnections) AS proxy_disconnections WHERE cluster IN ({{cluster}}) AND db IN ({{db}}) FACET proxy LIMIT MAX) SELECT sum(connections) - sum(client_disconnections) - sum(proxy_disconnections) AS 'active connections' SINCE 2 minutes ago"
              }
            ]
          }
        },
        {
          "title": "Avg OPS Per Second",
          "layout": {
            "column": 10,
            "row": 2,
            "width": 3,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM (FROM Metric SELECT ((max(endpoint_read_requests) - min(endpoint_read_requests)) + (max(endpoint_write_requests) - min(endpoint_write_requests)) + (max(endpoint_other_requests) - min(endpoint_other_requests))) / 60 AS value WHERE cluster IN ({{cluster}}) AND db IN ({{db}}) FACET proxy LIMIT MAX) SELECT sum(value) AS 'ops/sec' SINCE 2 minutes ago"
              }
            ]
          }
        },
