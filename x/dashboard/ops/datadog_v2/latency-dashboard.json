            "definition": {
              "type": "query_value",
              "title": "Avg OPS Per Second",
              "requests": [
                {
                  "q": "sum:rdse2.endpoint_other_requests.count{$cluster,$db}.as_rate()",
                  "aggregator": "last"
                }
              ],
              "autoscale": true,
              "precision": 2
            }
          }
        ]
      }
    },
    {
      "definition": {
        "type": "group",
