              "requests": [
                {
                  "q": "avg:rdse2.namedprocess_namegroup_cpu_seconds.count{$cluster,$db} by {node}.as_rate()",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
