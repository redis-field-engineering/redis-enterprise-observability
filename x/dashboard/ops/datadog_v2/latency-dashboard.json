          {
            "definition": {
              "type": "query_value",
              "title": "#Connections",
              "requests": [
                {
                  "q": "sum:rdse2.endpoint_client_connections{$cluster, $db} - sum:rdse2.endpoint_client_disconnections{$cluster, $db} - sum:rdse2.endpoint_proxy_disconnections{$cluster, $db}",
