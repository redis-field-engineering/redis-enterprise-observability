{
  "title": "Redis Enterprise - Latency Dashboard",
  "description": "Import-safe Datadog version of Latency Dashboard.",
  "widgets": [
    {
      "definition": {
        "type": "group",
        "layout_type": "ordered",
        "title": "Proxy Latency",
        "widgets": [
          {
            "definition": {
              "type": "timeseries",
              "title": "Avg Latency",
              "requests": [
                {
                  "q": "(avg:rdse2.endpoint_read_requests_latency_histogram{$cluster,$db}) / 1000",
                  "display_type": "line",
                  "style": {
                    "palette": "dog_classic",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "metadata": [
                    {
                      "expression": "(avg:rdse2.endpoint_read_requests_latency_histogram{$cluster,$db}) / 1000",
                      "alias_name": "read"
                    }
                  ]
                },
                {
                  "q": "(avg:rdse2.endpoint_write_requests_latency_histogram{$cluster,$db}) / 1000",
                  "display_type": "line",
                  "style": {
                    "palette": "warm",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "metadata": [
                    {
                      "expression": "(avg:rdse2.endpoint_write_requests_latency_histogram{$cluster,$db}) / 1000",
                      "alias_name": "write"
                    }
                  ]
                },
                {
                  "q": "(avg:rdse2.endpoint_other_requests_latency_histogram{$cluster,$db}) / 1000",
                  "display_type": "line",
                  "style": {
                    "palette": "cool",
                    "line_type": "solid",
                    "line_width": "normal"
                  },
                  "metadata": [
                    {
                      "expression": "(avg:rdse2.endpoint_other_requests_latency_histogram{$cluster,$db}) / 1000",
                      "alias_name": "other"
                    }
                  ]
                }
              ],
              "show_legend": true,
              "legend_layout": "auto",
              "legend_columns": [
                "avg",
                "min",
                "max",
                "value"
              ],
              "yaxis": {
                "include_zero": true,
                "scale": "linear",
                "label": "ms"
              }
            }
          },
          {
            "definition": {
              "type": "timeseries",
              "title": "Read Latency By Proxy",
              "requests": [
                {
                  "q": "(avg:rdse2.endpoint_read_requests_latency_histogram{$cluster,$db} by {proxy}) / 1000",
