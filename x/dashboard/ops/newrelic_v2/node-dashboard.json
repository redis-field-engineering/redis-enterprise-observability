{
  "name": "Redis Enterprise - Node Dashboard",
  "description": "New Relic implementation of the validated Redis Enterprise node operations dashboard.",
  "permissions": "PUBLIC_READ_WRITE",
  "pages": [
    {
      "name": "Node Dashboard",
      "description": null,
      "widgets": [
        {
          "title": "",
          "layout": {
            "column": 1,
            "row": 1,
            "width": 12,
            "height": 1
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.markdown"
          },
          "rawConfiguration": {
            "text": "# Redis Enterprise Node Dashboard\n\nNew Relic implementation of the validated Redis Enterprise node operations dashboard. Filter by `cluster` and `node`."
          }
        },
        {
          "title": "Status",
          "layout": {
            "column": 1,
            "row": 2,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM Metric SELECT max(node_metrics_up) AS 'status' WHERE cluster IN ({{cluster}}) AND node IN ({{node}}) SINCE 2 minutes ago"
              }
            ]
          }
        },
        {
          "title": "Enterprise Version",
          "layout": {
            "column": 3,
            "row": 2,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.table"
          },
          "rawConfiguration": {
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "facet": {
              "showOtherSeries": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM Metric SELECT latest(node_config) AS 'up' WHERE metricName = 'node_config' AND cluster IN ({{cluster}}) AND node IN ({{node}}) FACET rs_version LIMIT 1 SINCE 2 minutes ago"
              }
            ]
          }
        },
        {
          "title": "Role",
          "layout": {
            "column": 5,
            "row": 2,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM Metric SELECT max(is_primary) AS 'role' WHERE cluster IN ({{cluster}}) AND node IN ({{node}}) SINCE 2 minutes ago"
              }
            ]
          }
        },
        {
          "title": "# Shards",
          "layout": {
            "column": 7,
            "row": 2,
            "width": 2,
            "height": 3
          },
          "linkedEntityGuids": null,
          "visualization": {
            "id": "viz.billboard"
          },
          "rawConfiguration": {
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM Metric SELECT uniqueCount(redis) AS 'shards' WHERE metricName = 'redis_server_used_memory' AND cluster IN ({{cluster}}) AND node IN ({{node}}) SINCE 2 minutes ago"
              }
            ]
          }
        },
        {
          "title": "CPU Utilization",
          "layout": {
            "column": 9,
            "row": 2,
            "width": 2,
            "height": 3
