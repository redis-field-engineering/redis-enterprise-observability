          },
          "rawConfiguration": {
            "platformOptions": {
              "ignoreTimeRange": false
            },
            "nrqlQueries": [
              {
                "accountIds": [
                  0
                ],
                "query": "FROM Metric SELECT ((max(node_cpu_seconds_total) - min(node_cpu_seconds_total)) / 60) * 100 AS 'cpu %' WHERE mode != 'idle' AND cluster IN ({{cluster}}) AND node IN ({{node}}) SINCE 2 minutes ago"
              }
            ],
            "units": {
              "unit": "PERCENTAGE"
            }
          }
        },
